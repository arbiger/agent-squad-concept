# Calling Agent Squad: Orchestration
#
# A "One-Person Agency" orchestration pattern that dispatches specialized
# team members for business and development missions.
#
# Pattern: Matrix Squad
# roles: Orchestrator, Evaluator-Optimizer (Tier 0), Async Observer

input task: "The mission or project goal"
input project_name: "A short ID for the project (e.g., 'laser-distance-meter-us-market-research')"
input timestamp: "Current date (YYYYMMDD)"

# ============================================================================
# Agent Definitions
# ============================================================================

agent squad_manager:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Squad Manager — an orchestrator who never executes tasks directly.
Your role is to analyze the mission, scope the work, delegate to the right team members,
and synthesize final results. You never write code, copy, or research yourself.
Stay high-level, strategic, and decisive.
"""

agent observer:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Squad Observer — an async background agent responsible for logging mission
progress, extracting lessons learned, and maintaining the mission handbook.
You write structured logs with timestamps, phases, and outcomes.
"""

agent architect:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Architect — a systems thinker who designs structure before execution.
Your job is to break down the mission into clear phases, define deliverables,
and create a structured plan that other squad members can follow.
"""

agent researcher:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Market Researcher — facts first, no hallucinations.
Use web_search and web_fetch to gather real data. Synthesize insights,
identify consumer pain points, competitor weaknesses, and viral headline patterns.
Never write final marketing copy — that is the Copywriter's job.
"""

agent copywriter:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Copywriter — a creative, brand-aware communicator.
You transform raw research and structured outlines into polished, engaging content.
Write with clarity and punch. Follow the brand guidelines in handbook.md.
"""

agent brand_reviewer:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Brand Reviewer — a quality gatekeeper for all content output.
Review for brand alignment, tone consistency, factual accuracy, and clarity.
Output a structured audit: ✅ Strengths, ⚠️ Issues, 📝 Recommended Edits, and a Verdict.
"""

agent coder:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Coder — a production-quality software engineer.
Write clean, well-commented, and secure code. Follow the project architecture and
always check for edge cases and error handling.
"""

agent code_reviewer:
  model: minimax/MiniMax-M2.5
  prompt: """
You are the Code Reviewer — a meticulous engineer who audits for security vulnerabilities,
logic errors, and architectural compliance. Output a structured review with severity ratings.
"""

# ============================================================================
# Runtime Setup
# ============================================================================

let project_id = "{project_name}_{timestamp}"
let workspace = "Documents/squad_projects/{project_id}"

# ============================================================================
# Block Definitions: Reusable Quality-Control Loop
# ============================================================================

block execute-with-audit(executor, reviewer, goal, initial_context):
  let attempt = session: executor
    prompt: "Execute the following task: {goal}"
    context: initial_context
    working_dir: workspace

  loop (max: 2):
    let audit = session: reviewer
      prompt: "Review the output for correctness, security, and brand alignment"
      context: { attempt, goal }
      working_dir: workspace

    if **audit rejects the output**:
      let fix = session: executor
        prompt: "Address these issues from the reviewer: {audit}"
        context: { attempt, audit }
        working_dir: workspace
      set attempt = fix
    else:
      output result = attempt
      break

# ============================================================================
# Main Workflow: The Mission
# ============================================================================

# Phase 0: Mission Log Initialization
session: observer
  prompt: "Initialize a mission log file at {workspace}/mission_log.md. Record: Project={project_id}, Task={task}, Status=STARTED"
  working_dir: workspace

# Phase 1: Scoping & Architecture
let scope = session: squad_manager
  prompt: "[SCOPING] Analyze this mission and identify which squad roles are needed and in what order: {task}"

let blueprint = session: architect
  prompt: "Given the following scope, create a structured plan and architecture document. Save it to {workspace}/architecture.md"
  context: scope
  working_dir: workspace

# Phase 2: Execution & Quality Control
if **task is a software/development task**:
  let mission_result = do execute-with-audit(coder, code_reviewer, task, blueprint)
else if **task is marketing, content, or copywriting**:
  let mission_result = do execute-with-audit(copywriter, brand_reviewer, task, blueprint)
else:
  # Default: research task
  let research_data = session: researcher
    prompt: "Perform thorough research on: {task}. Save raw findings to {workspace}/research_data.md"
    working_dir: workspace

  let structured = session: architect
    prompt: "Organize the raw research into a structured report. Save to {workspace}/structured_report.md"
    context: research_data
    working_dir: workspace

  let final_report = session: copywriter
    prompt: "Polish the structured report into a clear, professional final report. Save to {workspace}/final_report.md"
    context: structured
    working_dir: workspace

  let review = session: brand_reviewer
    prompt: "Audit the final report for quality and accuracy. Save review notes to {workspace}/review_report.md"
    context: final_report
    working_dir: workspace

  let mission_result = final_report

# Phase 3: Retrospective
let retrospective = session: squad_manager
  prompt: "[ARBITRATION] Conduct a retrospective. What went well? What should be improved? Summarize lessons learned."
  context: mission_result

session: observer
  prompt: "Update {workspace}/mission_log.md with the mission outcome, key findings, and lessons learned. Mark Status=COMPLETED"
  context: { mission_result, retrospective }
  working_dir: workspace

# Phase 4: Final Summary
output result = session: squad_manager
  prompt: "[COMPLETE] Summarize the mission results for the user in a clear, structured format. Include key outputs, file locations, and any recommended next steps."
  context: { mission_result, retrospective }
